# ============================================================
# backend/.env.example
# Copy this to backend/.env and fill in your values
# ============================================================

# --- Server ---
PORT=5000
JWT_SECRET=your-very-secret-key-change-this

# --- Database (leave blank to use local JSON fallback) ---
DATABASE_URL=
DB_USER=postgres
DB_HOST=localhost
DB_NAME=data_collection
DB_PASSWORD=
DB_PORT=5432

# --- Google OAuth (for user login) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Google Drive (DISABLED — using S3) ---
GOOGLE_DRIVE_ENABLED=false

# --- AWS S3 (Primary data storage for surveys, tests, videos) ---
# On EC2 with IAM Role: leave ACCESS_KEY fields blank (auto-detected)
# On local dev: fill in your IAM user credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=data-collection-uploads

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5001
