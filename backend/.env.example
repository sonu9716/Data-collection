# ============================================================
# backend/.env.example
# Copy this to backend/.env and fill in your values
# ============================================================

# --- Server ---
PORT=5000
JWT_SECRET=your-very-secret-key-change-this

# --- Database (leave blank to use local JSON fallback) ---
DATABASE_URL=
DB_USER=postgres
DB_HOST=localhost
DB_NAME=data_collection
DB_PASSWORD=
DB_PORT=5432

# --- AWS S3 (optional, used if GOOGLE_DRIVE_ENABLED is false) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=data-collection-bucket

# --- Google OAuth ---
# OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Google Drive (preferred storage) ---
# Set to true to enable Google Drive for videos and exports
GOOGLE_DRIVE_ENABLED=true

# Path to your Service Account JSON key file (relative to backend/)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# Name of the root folder to create/use in Google Drive
GOOGLE_DRIVE_ROOT_FOLDER_NAME=DataCollection

# (Optional) If you shared a personal Google Drive folder with the service account,
# paste the folder ID here to use YOUR storage (e.g. 2TB Jio plan).
# Get the folder ID from the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5001
