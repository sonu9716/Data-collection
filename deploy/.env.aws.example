# ============================================================================
# AWS Free Tier Environment Variables for Data-Collection Backend
# Optimized for 50 concurrent users on t2.micro + RDS db.t3.micro
#
# Copy this to backend/.env on your EC2 instance and fill in values:
#   cp deploy/.env.aws.example backend/.env
#   nano backend/.env
# ============================================================================

# --- Server ---
PORT=5000
NODE_ENV=production
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# --- Database (Render PostgreSQL - Free Tier) ---
# Get the EXTERNAL URL from: Render Dashboard → your DB → Connections
# ⚠️ Use the EXTERNAL URL, not the internal one!
DATABASE_URL=postgresql://postgres:xxxx@dpg-xxxxx.oregon-postgres.render.com:5432/data_collection

# Connection pool size — keep small for free tier (1GB RAM on t2.micro)
# 5 connections handles 50 concurrent users easily
DB_POOL_SIZE=5

# --- Google OAuth (for user login via Google) ---
# Same Client ID used on Render — no change needed
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_DRIVE_CLIENT_ID=YOUR_GOOGLE_DRIVE_CLIENT_ID
GOOGLE_DRIVE_CLIENT_SECRET=YOUR_GOOGLE_DRIVE_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_GOOGLE_REFRESH_TOKEN
GOOGLE_DRIVE_ROOT_FOLDER_NAME=DataCollection

# --- AWS S3 (OPTIONAL fallback video storage) ---
# Only needed if Google Drive is disabled
# S3 free tier: 5GB storage, 20K GET, 2K PUT per month
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=data-collection-uploads

# --- CORS ---
# Add your S3 frontend website URL here
# Format: http://BUCKET-NAME.s3-website.REGION.amazonaws.com
CORS_ORIGINS=http://YOUR-FRONTEND-BUCKET.s3-website.ap-south-1.amazonaws.com,http://localhost:3000
